# Copy to `.env` for local dev. For Vercel, add the same variable in
# Project → Settings → Environment Variables (Production + Preview as needed).
#
# Create a free Postgres on https://neon.tech. After changing the schema,
# apply migrations locally or in CI against production: npm run db:migrate:deploy
# (needs DATABASE_URL pointing at your DB; pooling URL is fine for runtime).
#
# In Vercel you can also: Add Integration → Neon to create the DB and wire env automatically.

DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB_NAME?sslmode=require"
