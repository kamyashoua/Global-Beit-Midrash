// Prisma schema — published islands shared across all visitors.
// On Vercel, use a hosted Postgres (e.g. Neon). See `.env.example`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Hosted Postgres URL (Neon, etc.). Migrations run via npm run db:migrate:deploy, not during Vercel build.
  url      = env("DATABASE_URL")
}

model PublishedIsland {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  groupName   String
  valueIds    Json
  textIds     Json
  practiceIds Json
  reflection  String
}
