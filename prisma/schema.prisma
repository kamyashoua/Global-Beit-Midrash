// Prisma schema — published islands shared across all visitors.
// On Vercel, use a hosted Postgres (e.g. Neon). See `.env.example`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Use a hosted Postgres connection string (Neon: use the direct / non-pooling URL
  // for both local dev and Vercel so `migrate deploy` works in CI/build).
  url      = env("DATABASE_URL")
}

model PublishedIsland {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  groupName   String
  valueIds    Json
  textIds     Json
  practiceIds Json
  reflection  String
}
